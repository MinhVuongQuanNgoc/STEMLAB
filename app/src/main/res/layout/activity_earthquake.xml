<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvEarthquakeTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Earthquake-Resistant Structure"
            android:textColor="#1B5E20"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvEarthquakeInstruction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Place the phone on the structure platform, gently shake the table or platform, and observe the movement strength. Lower peak movement means better vibration resistance."
            android:textSize="16sp"
            android:layout_marginBottom="20dp" />

        <EditText
            android:id="@+id/etStructureDesign"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Structure design notes, e.g. 10 folds + 4 pillars"
            android:inputType="textMultiLine"
            android:minLines="2" />

        <TextView
            android:id="@+id/tvCurrentMovement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Current Movement: 0.00"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp" />

        <TextView
            android:id="@+id/tvPeakMovement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Peak Movement: 0.00"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/tvStabilityRating"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stability Rating: Not measured"
            android:textSize="18sp"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnStartEarthquakeTest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start Vibration Test"
            android:layout_marginTop="24dp" />

        <Button
            android:id="@+id/btnStopEarthquakeTest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stop Vibration Test"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnResetEarthquakeTest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reset Peak Movement"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/tvEarthquakeResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Result will appear here."
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <Button
            android:id="@+id/btnBackFromEarthquake"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Back"
            android:layout_marginTop="24dp" />

    </LinearLayout>

</ScrollView>