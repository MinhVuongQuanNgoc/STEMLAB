<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvReactionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reaction Board Challenge"
            android:textColor="#1B5E20"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvReactionInstruction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap the target as soon as it appears. Do not tap too early. Repeat attempts to compare reaction speed."
            android:textSize="16sp"
            android:layout_marginBottom="20dp" />

        <EditText
            android:id="@+id/etReactionNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Attempt notes, e.g. dominant hand / non-dominant hand"
            android:inputType="text" />

        <TextView
            android:id="@+id/tvReactionStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Press Start Round to begin."
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnReactionTarget"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:text="WAIT"
            android:textSize="26sp"
            android:enabled="false"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvReactionTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Last Reaction Time: Not measured"
            android:textSize="18sp"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tvReactionStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Attempts: 0"
            android:textSize="18sp"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tvReactionRating"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Rating: Not measured"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnStartReactionRound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start Round" />

        <Button
            android:id="@+id/btnResetReaction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reset Results"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnBackFromReaction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Back"
            android:layout_marginTop="24dp" />

    </LinearLayout>

</ScrollView>