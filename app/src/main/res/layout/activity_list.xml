<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1B5E20"
            app:cardBackgroundColor="#E8F5E9">

            <TextView
                android:id="@+id/tvWelcomeTeam"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="Welcome, Team"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:gravity="center" />

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="STEMM Activities"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Choose a real-world STEMM challenge to begin."
            android:textSize="16sp"
            android:textColor="#555555"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnParachute"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Parachute Drop Challenge" />

        <Button
            android:id="@+id/btnSound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sound Pollution Hunter"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnFan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hand Fan Challenge"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnEarthquake"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Earthquake-Resistant Structure"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnPerformance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Human Performance Lab"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnReaction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reaction Board Challenge"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnBreathing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Breathing Pace Trainer"
            android:layout_marginTop="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLeaderboard"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="View Global Leaderboard"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"
            app:icon="@drawable/ic_leaderboard"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            app:iconTint="#1B5E20"
            app:cornerRadius="12dp" />
    </LinearLayout>

</ScrollView>